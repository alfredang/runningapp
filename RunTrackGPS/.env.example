# RunTrack GPS — App Store Connect submission config.
# Copy to a gitignored `.env` at the repo root and fill in. Load before running scripts:
#   set -a; source .env; set +a
# The `.p8` private key itself is NEVER committed — keep it at ASC_PRIVATE_KEY_PATH.
# NOTE: uploading to the App Store requires a PAID Apple Developer Program membership
# and an App Store Connect API key (generated once in the ASC web UI).

# --- App Store Connect API credentials ---
ASC_KEY_ID=YOURKEYID
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_YOURKEYID.p8

# --- App identity ---
ASC_BUNDLE_ID=com.tertiaryinfotech.runtrackgps
# ASC_APP_ID=             # optional; numeric ASC id (resolved from bundle id if blank)

# --- Version metadata --- (quote any value with spaces so `source .env` works)
ASC_COPYRIGHT="2026 Tertiary Infotech Pte Ltd"
ASC_PRIVACY_POLICY_URL="https://www.example.com/runtrackgps/privacy"
ASC_SUPPORT_URL="https://www.example.com/runtrackgps"
ASC_MARKETING_URL="https://www.example.com/runtrackgps"

# --- App Review contact ---
ASC_CONTACT_FIRST="Alfred"
ASC_CONTACT_LAST="Ang"
ASC_CONTACT_PHONE="+6500000000"
ASC_CONTACT_EMAIL="angchewhoe@gmail.com"
ASC_REVIEW_NOTES="No login required. Grant Location (Always) + Microphone/Speech to test GPS tracking and voice control."
